# Required
BOT_TOKEN=123456:ABC-your-telegram-bot-token

# Optional
LOG_LEVEL=INFO
TEMP_DIR=
# Max bytes to send as Telegram file (default ~49MB under 50MB API limit)
TELEGRAM_MAX_FILE_BYTES=51380224
# Target max size after compression (bytes)
COMPRESS_TARGET_BYTES=48234496
# Enable ffmpeg compression for oversized videos (uses extra RAM/CPU). Keep false on small instances.
ENABLE_COMPRESSION=false
# How many downloads can run at once. Use 1 on low-memory hosts.
MAX_CONCURRENT_DOWNLOADS=1
# Netscape cookies.txt from a browser logged into instagram.com — often required for
# public reels too when the bot runs on a cloud IP (e.g. Render). Optional.
COOKIES_FILE=
# Optional: cookies.txt logged into x.com (auth_token, ct0). Used for X/Twitter downloads;
# if unset, COOKIES_FILE is also tried for Twitter when it includes x.com / twitter.com rows.
TWITTER_COOKIES_FILE=
